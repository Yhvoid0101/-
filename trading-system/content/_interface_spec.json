{
  "_spec_version": "1.0",
  "purpose": "六智能体间数据交换规范 — 确保信息流通顺畅性、一致性、安全性",
  "data_format": {
    "primary": "JSON (UTF-8 编码)",
    "secondary": "JSONL (每行一条 JSON, 用于流式数据)",
    "numeric": "float (保留 6 位小数)",
    "timestamp": "ISO 8601 UTC (e.g., 2026-06-27T15:30:00Z)",
    "encoding": "UTF-8 without BOM",
    "schema_validation": "JSON Schema draft-07"
  },
  "transmission_frequency": {
    "real_time": {
      "description": "实时数据 (行情/订单)",
      "max_latency_ms": 100,
      "protocol": "WebSocket",
      "owner": "AGENT_4"
    },
    "high_freq": {
      "description": "高频同步 (交易信号/仓位变更)",
      "frequency": "每分钟",
      "protocol": "JSON 文件 + inotify",
      "owner": "AGENT_1, AGENT_6"
    },
    "mid_freq": {
      "description": "中频同步 (分析报告/差异评估)",
      "frequency": "每轮进化 (约每小时)",
      "protocol": "JSON 文件",
      "owner": "AGENT_2, AGENT_3, AGENT_5"
    },
    "low_freq": {
      "description": "低频同步 (进度报告/责任矩阵)",
      "frequency": "每4小时",
      "protocol": "JSON 文件 + 协调日志",
      "owner": "ALL"
    }
  },
  "validation_mechanism": {
    "integrity_check": {
      "method": "SHA-256 checksum",
      "field": "_checksum",
      "scope": "整个 JSON 内容"
    },
    "schema_check": {
      "method": "JSON Schema 验证",
      "fields_required": [
        "_meta.version",
        "_meta.generated_by",
        "_meta.timestamp"
      ]
    },
    "consistency_check": {
      "method": "交叉引用验证 (L3)",
      "scope": "文件路径引用、模块名引用、Agent ID 引用"
    },
    "security_check": {
      "method": "密钥扫描 (L6 SecurityScanner)",
      "blocked_patterns": [
        "api_key=",
        "password=",
        "secret=",
        "token="
      ]
    }
  },
  "file_naming_convention": {
    "pattern": "_<功能名>_<修饰>.<扩展名>",
    "examples": [
      "_enhanced_gene_analysis_report.json",
      "_shap_gene_analysis_report.json",
      "_redundancy_report_v2.json",
      "_sim_live_gap_multi_pair_report.json",
      "_coordination_log_agent4_live_data_connector.py",
      "_progress_report_agent4_round_N.json"
    ],
    "prefix_underscore": "表示内部生成文件 (区别于用户源代码)",
    "versioning": "_v2, _v3 后缀表示版本迭代"
  },
  "agent_interfaces": {
    "AGENT_1_STRATEGY_EVOLVER": {
      "outputs": [
        "population_gen_N.jsonl — 种群快照",
        "audit.log — 进化审计日志"
      ],
      "inputs_needed": [
        "AGENT_2: 显著亏损基因清单 → 用于定向突变",
        "AGENT_3: REMOVE模块清单 → 用于下线",
        "AGENT_6: 风控熔断信号 → 用于暂停进化"
      ]
    },
    "AGENT_2_GENE_ANALYZER": {
      "outputs": [
        "_enhanced_gene_analysis_report.json — 统计+RF+PI",
        "_shap_gene_analysis_report.json — SHAP值"
      ],
      "inputs_needed": [
        "AGENT_1: population_gen_*.jsonl — 种群数据",
        "AGENT_5: 模拟-实盘gap基因归因 → 关联基因与gap"
      ]
    },
    "AGENT_3_REDUNDANCY_HUNTER": {
      "outputs": [
        "_redundancy_report_v2.json — 4维矩阵结果",
        "_refactor_plan_<module>.json — 重构计划"
      ],
      "inputs_needed": [
        "AGENT_1: 模块调用频率统计",
        "AGENT_2: 模块影响权重",
        "AGENT_4: 真实环境模块性能"
      ]
    },
    "AGENT_4_LIVE_DATA_CONNECTOR": {
      "outputs": [
        "_real_data_gateway.py — 数据网关",
        "multi_exchange_provider.py — 多交易所聚合",
        "_latency_monitor_report.json — 延迟监控"
      ],
      "inputs_needed": [
        "AGENT_1: 需要的交易对清单",
        "AGENT_5: 需要复现的行情场景",
        "AGENT_6: 订单执行结果反馈"
      ]
    },
    "AGENT_5_SIM_LIVE_GAP_ANALYST": {
      "outputs": [
        "_sim_live_gap_multi_pair_report.json — 多对多行情差异",
        "_sim_live_gap_model.py — 5模块成本模型"
      ],
      "inputs_needed": [
        "AGENT_1: 模拟交易日志",
        "AGENT_4: 真实行情数据 (用于校准模型)",
        "AGENT_2: 亏损基因 (用于归因)"
      ]
    },
    "AGENT_6_RISK_GUARDIAN": {
      "outputs": [
        "_risk_guardian.py — 风控守门员",
        "_circuit_breaker.py — 熔断器",
        "_monthly_risk_report.json — 月度风控报告"
      ],
      "inputs_needed": [
        "AGENT_4: 实盘订单执行状态",
        "AGENT_5: gap恶化信号",
        "AGENT_1: 当前种群风险偏好"
      ]
    }
  }
}